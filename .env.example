# Адмін-панель /admin/bookings (пароль для входу)
# ADMIN_PASSWORD=

# PostgreSQL (приклад для локального Docker: docker compose up -d)
DATABASE_URL=postgresql://pool:pool@localhost:5432/pool

# Швидкий прототип без міграцій (не запускайте db:migrate з тим самим URL):
# TYPEORM_SYNC=true

# Додаткові логи SQL (1 / 0)
# TYPEORM_LOGGING=1

# Публічний URL сайту (для redirectUrl після оплати Monobank). У проді: https://ваш-домен
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Monobank інтернет-еквайринг — токен з https://web.monobank.ua/ (лише сервер)
# Документація: https://monobank.ua/api-docs/acquiring/methods/ia/post--api--merchant--invoice--create
# MONOBANK_TOKEN=
# MONOBANK_API_URL=https://api.monobank.ua

# Опційно: повний URL вебхука (POST), наприклад https://ваш-домен/api/webhooks/monobank
# MONOBANK_WEBHOOK_URL=

# Синхронізація «хтось обирає місце» — через полінг + БД (працює на Vercel + Neon,
# окремий процес більше не потрібен). Усі значення нижче опційні.
# Інтервал опитування стану карти браузером (мс)
# NEXT_PUBLIC_SEAT_POLL_MS=4000
# Скільки тримати власну «чернетку» без активності, поки не скинути (мс)
# NEXT_PUBLIC_SEAT_DRAFT_TTL_MS=300000
# Скільки утримання живе в БД без heartbeat (мс), має бути > NEXT_PUBLIC_SEAT_POLL_MS
# SEAT_HOLD_TTL_MS=30000
